# Copy to .env and fill in values. Never commit .env.

# PostgreSQL
# Local dev (docker-compose): postgres://judgemind:localdev@localhost:5432/judgemind
# Production: retrieve from AWS Secrets Manager
DATABASE_URL=postgres://judgemind:localdev@localhost:5432/judgemind

# Redis
# Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production

# Object Storage (local dev uses MinIO via docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-west-2
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_DOCUMENT_ARCHIVE_BUCKET=judgemind-document-archive-dev

# Transactional Email (Amazon SES)
# Production: set AWS credentials via instance role or environment variables.
# Local dev: emails are not sent (SES calls will fail without credentials — mock or skip in dev).
AWS_REGION=us-west-2
EMAIL_FROM=no-reply@judgemind.org
# SES configuration set name — from Terraform output ses_configuration_set_name
SES_CONFIGURATION_SET=judgemind-dev

# App
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
