{
  "permissions": {
    "allow": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git add*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git pull*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git merge*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git rebase*)",
      "Bash(git show*)",
      "Bash(git restore*)",
      "Bash(git -C* show*)",
      "Bash(git -C* restore*)",
      "Bash(git -C* commit*)",
      "Bash(git -C* push*)",
      "Bash(git -C* add*)",
      "Bash(git -C* status*)",
      "Bash(git -C* log*)",
      "Bash(git -C* diff*)",
      "Bash(git -C* pull*)",
      "Bash(git -C* checkout*)",
      "Bash(git -C* branch*)",
      "Bash(git -C* merge*)",
      "Bash(git -C* tag*)",
      "Bash(git -C* stash*)",
      "Bash(git -C* fetch*)",
      "Bash(git -C* rebase*)",
      "Bash(git -C* worktree*)",
      "Bash(gh issue*)",
      "Bash(gh pr*)",
      "Bash(gh api*)",
      "Bash(gh secret*)",
      "Bash(gh label*)",
      "Bash(gh project*)",
      "Bash(gh auth*)",
      "Bash(.venv/bin/pytest*)",
      "Bash(.venv/bin/pip*)",
      "Bash(.venv/bin/python*)",
      "Bash(python3*)",
      "Bash(pip3*)",
      "Bash(brew install*)",
      "Bash(brew upgrade*)",
      "Bash(npm*)",
      "Bash(terraform*)",
      "Bash(aws*)",
      "Bash(curl*)",
      "Bash(tar*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(mkdir*)",
      "Bash(ls*)",
      "Bash(wc*)",
      "Bash(find*)",
      "Bash(echo*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-end.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
